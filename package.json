{
  "name": "vestigios-api",
  "version": "1.0.0",
  "private": true,
  "description": "API do YouTube para o site Vestígios RPG — busca e cache de vídeos do canal",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "biome check src/",
    "format": "biome format --write src/"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/node": "^26.0.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.7",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
